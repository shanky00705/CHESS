<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chess Game</title>

  <!-- Tailwind -->
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <style>
    body {
      background: radial-gradient(circle at top, #1f2933, #020617);
    }

    /* ===== GAME CARD ===== */
    .game-card {
      background: #020617;
      border-radius: 20px;
      box-shadow: 0 30px 80px rgba(0,0,0,0.8);
      padding: 20px;
      width: 100%;
      max-width: 420px;
    }

    /* ===== HEADER ===== */
    .game-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
      color: #e5e7eb;
    }

    .badge {
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
    }

    .badge.white { background: #e5e7eb; color: #111; }
    .badge.black { background: #111; color: #fff; }
    .badge.spectator { background: #334155; color: #e5e7eb; }

    /* ===== BOARD ===== */
    .chessboard {
      display: grid;
      grid-template-columns: repeat(8, 1fr);
      grid-template-rows: repeat(8, 1fr);
      aspect-ratio: 1 / 1;
      border-radius: 16px;
      overflow: hidden;
      background: #111;
      box-shadow:
        inset 0 0 0 6px #020617,
        0 20px 40px rgba(0,0,0,0.7);
    }

    .chessboard.flipped {
      transform: rotate(180deg);
    }

    .chessboard.flipped .piece {
      transform: rotate(180deg);
    }

    /* ===== SQUARES ===== */
    .square {
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 34px;
      transition: background 0.15s ease;
    }

    .square.light { background: #f0d9b5; }
    .square.dark { background: #b58863; }

    .square.highlight {
      background: radial-gradient(circle, #a7f3d0 30%, transparent 32%);
    }

    .square.source {
      box-shadow: inset 0 0 0 3px #2563eb;
    }

    .square.target {
      box-shadow: inset 0 0 0 3px #dc2626;
    }

    /* ===== PIECES ===== */
    .piece {
      cursor: grab;
      transition: transform 0.15s ease;
    }

    .piece:active {
      cursor: grabbing;
      transform: scale(1.2);
    }

    .piece.white {
      color: #ffffff;
      text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    }

    .piece.black {
      color: #0f172a;
      text-shadow: 0 2px 4px rgba(255,255,255,0.4);
    }

    /* ===== FOOTER ===== */
    .game-footer {
      margin-top: 12px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      color: #94a3b8;
    }
  </style>
</head>

<body class="min-h-screen flex items-center justify-center px-4">

  <div class="game-card">
    <!-- HEADER -->
    <div class="game-header">
      <h1 class="text-lg font-semibold tracking-wide">♟ Chess Online</h1>
      <!-- JS can update this badge later -->
      <span class="badge spectator" id="playerRole">Spectator</span>
    </div>

    <!-- BOARD -->
    <div class="chessboard"></div>

    <!-- FOOTER -->
    <div class="game-footer">
      <span id="turnIndicator">Waiting for opponent…</span>
      <span class="opacity-60">Drag to move</span>
    </div>
  </div>

  <!-- Socket.IO -->
  <script src="https://cdn.socket.io/4.8.3/socket.io.min.js"></script>

  <!-- Chess.js -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"></script>

  <!-- Game Logic -->
  <script src="/js/chessgame.js"></script>
</body>
</html>
